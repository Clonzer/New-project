{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:render": "pnpm run typecheck && pnpm run build:frontend",
    "build:frontend": "pnpm --filter @workspace/print3d build",
    "build:backend": "pnpm --filter @workspace/api-server build",
    "contests:manage": "pnpm --filter @workspace/scripts run contests:manage",
    "contests:process-winners": "pnpm --filter @workspace/scripts run contests:process-winners",
    "db:migrate": "pnpm --filter @workspace/scripts run migrate",
    "start": "pnpm run start:render",
    "start:backend": "node artifacts/api-server/dist/index.cjs",
    "start:render": "pnpm --filter @workspace/print3d serve",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
